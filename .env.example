# Postgres connection string (any provider — Railway/Neon/Supabase/self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Optional service secret (sync-check / admin — full access to ALL docs).
# Leave unset to disable service auth. If set it must be 16+ chars; generate:
#   openssl rand -hex 32
COLLAB_TOKEN=
# Port for the sync server
PORT=3001
# OpenRouter API key for AI markdown conversion (POST /api/convert, `mdocs convert`).
# Leave unset to disable the endpoint. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: model slug for AI conversion (default: qwen/qwen3.6-flash)
OPENROUTER_MODEL=
